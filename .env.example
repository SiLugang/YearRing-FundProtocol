# ============================================================
# FinancialBase V01 — Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to git
# ============================================================

# ------------------------------------------------------------
# Deployer private key (hex, with 0x prefix)
# ------------------------------------------------------------
PRIVATE_KEY=0x...

# ------------------------------------------------------------
# Demo persona private keys (required for seed_v2.ts on testnet)
# Must be distinct from PRIVATE_KEY — no silent fallback
# Fund each with ~0.05 ETH for gas; no USDC needed (seed mints automatically)
# ------------------------------------------------------------
ALICE_PRIVATE_KEY=0x...
BOB_PRIVATE_KEY=0x...
CAROL_PRIVATE_KEY=0x...

# ------------------------------------------------------------
# RPC endpoints
# Base Sepolia: 公共节点可用（测试网）
# Base Mainnet: 必须使用正式节点（QuickNode 或 Alchemy），禁止使用 https://mainnet.base.org
#   QuickNode: https://dashboard.quicknode.com → Create Endpoint → Base → HTTPS
#   Alchemy:   https://dashboard.alchemy.com  → Create App → Base → HTTPS endpoint
# 可选：WSS endpoint（用于事件订阅，HTTP 够用则可不填）
# ------------------------------------------------------------
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_MAINNET_RPC_URL=https://<your-endpoint>.base-mainnet.quiknode.pro/<token>/
BASE_MAINNET_WSS_URL=wss://<your-endpoint>.base-mainnet.quiknode.pro/<token>/

# ------------------------------------------------------------
# Basescan API key (for contract verification)
# Get one at https://basescan.org/myapikey
# ------------------------------------------------------------
BASESCAN_API_KEY=

# ------------------------------------------------------------
# Protocol roles  (use Gnosis Safe addresses on mainnet)
# If not set, deployer address is used (local only)
# ------------------------------------------------------------
ADMIN_ADDRESS=
GUARDIAN_ADDRESS=
TREASURY_ADDRESS=

# ------------------------------------------------------------
# build_merkle.ts overrides  (optional)
# ------------------------------------------------------------
VAULT_ADDRESS=
SNAPSHOT_BLOCK=
EPOCH_ID=1
EPOCH_CAP=
